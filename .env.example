# Optional: path to SQLite file for /prefs (default: ./data/botarr.sqlite)
# BOTARR_DB_PATH=

# --- Telegram (required) ---
TELEGRAM_BOT_TOKEN=
# Comma- or space-separated numeric user IDs allowed to use the bot
TELEGRAM_ALLOWED_USER_IDS=
# Legacy single ID (merged with TELEGRAM_ALLOWED_USER_IDS if both set)
# TELEGRAM_ALLOWED_USER_ID=

# --- LLM (agent) ---
# openai_responses = OpenAI Responses API (needs OPENAI_API_KEY)
# local_openai_compat = Ollama / LM Studio / any OpenAI-compatible /v1/chat/completions
LLM_PROVIDER=openai_responses
OPENAI_API_KEY=
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=gpt-5

# --- Radarr / Sonarr (required; validated at startup) ---
RADARR_URL=
RADARR_API_KEY=
SONARR_URL=
SONARR_API_KEY=

# --- Plex (optional; omit both to run without Plex) ---
# PLEX_URL=
# PLEX_TOKEN=
